# --- Database ---------------------------------------------------------------
DATABASE_URL="postgresql://petmatch:petmatch@localhost:5432/petmatch?schema=public"

# --- Server -----------------------------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:8081,exp://localhost:8081"

# --- Auth -------------------------------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# --- Firebase Cloud Messaging (Poison alerts) -------------------------------
# Path to a service-account JSON downloaded from Firebase console.
# Leave empty to use FCM in dry-run mode (logs payload, no push sent).
FIREBASE_SERVICE_ACCOUNT_PATH=""
# Or, set the full JSON inline:
FIREBASE_SERVICE_ACCOUNT_JSON=""

# --- Geofencing -------------------------------------------------------------
POISON_ALERT_RADIUS_KM=2
POISON_ALERT_TTL_HOURS=48

# --- Mock Greek municipalities ----------------------------------------------
# Used by POST /api/reports to auto-assign the closest municipality.
# Format: "Δήμος Χ|34.5|33.0;Δήμος Υ|41.0|28.5"
GREEK_MUNICIPALITIES="Δήμος Αθηναίων|37.9842|23.7351;Δήμος Θεσσαλονίκης|40.6401|22.9444;Δήμος Πατρέων|38.2466|21.7346;Δήμος Ηρακλείου|35.3387|25.1441;Δήμος Λαρισαίων|39.6390|22.4191;Δήμος Βόλου|39.3624|22.9409;Δήμος Ιωαννιτών|39.6650|20.8537;Δήμος Καβάλας|40.9396|24.4012;Δήμος Ρόδου|36.4412|28.2225;Δήμος Κέρκυρας|39.6243|19.9217"
