model User {
  id                    String   @id @default(uuid()) @db.Uuid
  email                 String   @unique
  passwordHash          String?
  fullName              String?
  avatarUrl             String?
  role                  Role     @default(CITIZEN)
  karmaPoints           Int      @default(0)
  /** Preferred UI language. Drives email rendering today + future UI locale. */
  locale                String   @default("el")
  pushToken             String?
  homeLatitude          Float?
  homeLongitude         Float?
  lastSeenAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt